# Environment
ENV=development
DEBUG=true

# Server (8010 — ne pas utiliser 8000, réservé à DevLeadHunter en local)
HOST=0.0.0.0
PORT=8010
API_BASE_URL=http://localhost:8010

# CORS (dashboard web + desktop Tauri origins are added automatically)
CORS_ORIGINS=http://localhost:3003,http://localhost:1420

# Database (MariaDB in docker-compose, port 3311)
DATABASE_URL=mysql+pymysql://root:root@localhost:3311/nightforge

# JWT
SECRET_KEY=dev-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Admin user (created by the seeder)
ADMIN_EMAIL=contact@dibodev.fr
ADMIN_PASSWORD=admin123

# Encryption key for agent tokens / secrets
# generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Frontend URL (for links)
FRONTEND_URL=http://localhost:3003

# Groq — cloud fallback for Aide prompts IA when no agent is online
GROQ_API_KEY=
# Optional override (default: llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile