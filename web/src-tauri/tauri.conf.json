{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NightForge",
  "version": "0.1.0",
  "identifier": "fr.dibodev.nightforge",
  "build": {
    "beforeDevCommand": "node scripts/dev-desktop.mjs",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run desktop:generate",
    "frontendDist": "../.output/public"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "NightForge",
        "width": 1440,
        "height": 900,
        "resizable": true,
        "minWidth": 1000,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"],
    "externalBin": ["binaries/nightforge-agent"],
    "windows": {
      "nsis": {
        "installerHooks": "./windows/hooks.nsh"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": ["https://github.com/dibodev/nightforge/releases/latest/download/latest.json"],
      "pubkey": "__TAURI_UPDATER_PUBKEY__"
    }
  }
}
