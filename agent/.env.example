# Control-plane base URL (VPS in prod, localhost in dev)
NF_API_BASE=http://localhost:8010

# Agent token issued by the dashboard when registering this machine (shown once)
NF_AGENT_TOKEN=

# Optional: path to the claude CLI if not on PATH
NF_CLAUDE_BIN=claude

# Heartbeat / quota poll interval (seconds)
NF_TICK_SECONDS=30

# Fallback wait before retrying after a quota hit with no parsed reset time (seconds)
NF_QUOTA_RETRY_SECONDS=900

# Consecutive item failures tolerated before a run is aborted
NF_ERROR_BUDGET=3
