# Control-plane base URL (VPS in prod, localhost in dev)
NF_API_BASE=http://localhost:8010

# Agent token issued by the dashboard when registering this machine (shown once)
NF_AGENT_TOKEN=

# Optional: path to the claude CLI if not on PATH
NF_CLAUDE_BIN=claude

# Optional: path to the Cursor Agent CLI if not on PATH (Windows: agent.cmd)
NF_CURSOR_BIN=agent

# NightForge injects CLAUDE_CODE_OAUTH_TOKEN only when it spawns Claude Code subprocesses.
# Do not set it globally — it conflicts with Cursor / Claude Code's own auth flow.

# Heartbeat / quota poll interval while idle (seconds)
NF_TICK_SECONDS=60

# Heartbeat interval while a run is active (seconds)
NF_TICK_SECONDS_WORKING=30

# Fallback wait before retrying after a quota hit with no parsed reset time (seconds)
NF_QUOTA_RETRY_SECONDS=900

# Consecutive item failures tolerated before a run is aborted
NF_ERROR_BUDGET=3
